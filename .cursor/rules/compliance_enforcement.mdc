# Compliance Enforcement System (CES)
# =================================
# IMPERATIVE - CRITICAL SYSTEM COMPONENT
# This file defines the infallible system for rule compliance enforcement.
# DO NOT MODIFY WITHOUT EXPLICIT USER AUTHORIZATION.

# System State Definition
# ---------------------
state_definition:
  rules_loaded: boolean
  last_verification: timestamp
  active_violations: array
  verification_attempts: integer
  user_override_active: boolean
  override_reason: string
  override_timestamp: timestamp
  override_duration: duration

# Verification Protocol Definition
# -----------------------------
verification_protocol:
  initial_load:
    priority: "HIGHEST"
    required_files:
      - ".cursor/rules/session_startup.mdc"
      - ".cursor/rules/interaction_protocols.mdc"
      - ".cursor/rules/learned-memories.mdc"
      - ".cursor/rules/commit_standards.mdc"
      - ".cursor/rules/ci_cd_commit_policy.mdc"
      - ".cursor/rules/cli_banner_standard.mdc"
      - ".cursor/rules/create_rules.mdc"
      - ".cursor/rules/memory.mdc"
    validation_rules:
      - "ALL files MUST exist"
      - "ALL files MUST be loadable"
      - "ALL files MUST be valid .mdc format"
      - "NO file can be empty"
    failure_action:
      - "STOP ALL OPERATIONS"
      - "Notify user of missing/unloadable files"
      - "Provide exact list of missing files"
      - "Wait for user instruction"

  continuous_verification:
    check_points:
      - "before_code_edit"
      - "before_file_creation"
      - "before_command_execution"
      - "before_rule_application"
    validation_rules:
      - "Current state MUST match expected state"
      - "NO active violations allowed"
      - "ALL rules MUST be compliant"
    failure_action:
      - "STOP current action"
      - "Notify user of violation"
      - "Wait for explicit user instruction"

# Violation Detection Definition
# ----------------------------
violation_detection:
  model_behavior:
    triggers:
      - "excessive_helpfulness"
      - "proactive_behavior"
      - "rule_interpretation"
      - "assumption_making"
    detection_rules:
      - "ANY model-specific behavior MUST be detected"
      - "ALL violations MUST be logged"
      - "ALL violations MUST be timestamped"
    action_rules:
      - "IMMEDIATELY STOP current action"
      - "Log violation with timestamp"
      - "Notify user of specific violation"
      - "Wait for explicit user instruction"

  rule_violation:
    triggers:
      - "rule_override_attempt"
      - "flexible_interpretation"
      - "assumed_approval"
      - "unverified_action"
    detection_rules:
      - "ANY rule violation MUST be detected"
      - "ALL violations MUST be logged with context"
      - "ALL violations MUST be timestamped"
    action_rules:
      - "IMMEDIATELY STOP current action"
      - "Log violation with context"
      - "Notify user of specific rule violated"
      - "Wait for explicit user instruction"

# User Override Definition
# ----------------------
user_override:
  requirements:
    - "explicit_user_request"
    - "override_reason"
    - "override_duration"
  validation_rules:
    - "ALL requirements MUST be met"
    - "Override MUST be logged"
    - "User MUST confirm"
  monitoring_rules:
    - "Monitor for abuse"
    - "Track override duration"
    - "Verify override scope"
  violation_action:
    - "IMMEDIATELY STOP"
    - "Notify user"
    - "Revert to strict compliance"
    - "Wait for explicit user instruction"

# Recovery Protocol Definition
# --------------------------
recovery_protocol:
  violation_recovery:
    triggers:
      - "violation_detected"
      - "override_expired"
      - "system_error"
    validation_rules:
      - "ALL operations MUST stop"
      - "Incident MUST be logged"
      - "User MUST be notified"
    action_rules:
      - "Wait for explicit user instruction"
      - "Verify system state"
      - "Confirm all rules active"

  state_recovery:
    triggers:
      - "session_interruption"
      - "rule_reload"
      - "state_corruption"
    validation_rules:
      - "ALL rules MUST be verified"
      - "System state MUST be verified"
      - "User context MUST be verified"
    action_rules:
      - "Log recovery action"
      - "Wait for ALL verifications"
      - "Proceed only when ALL verified"

# Implementation Rules
# ------------------
implementation_rules:
  - "This system MUST be loaded FIRST"
  - "This system CANNOT be overridden"
  - "Modification requires explicit user authorization"
  - "System MUST stop ALL operations if compliance cannot be guaranteed"
  - "System MUST verify ALL .mdc files in .cursor/rules/"
  - "System MUST maintain complete verification and violation logs"

# Usage Rules
# ----------
usage_rules:
  - "System MUST be loaded at session start"
  - "System MUST verify ALL .mdc files in .cursor/rules/"
  - "System MUST monitor ALL actions"
  - "System can ONLY be overridden by explicit user instruction"
  - "System MUST maintain complete verification and violation logs"

# REMINDER: THIS SYSTEM IS IMPERATIVE AND TAKES PRECEDENCE OVER ALL OTHER SYSTEMS
# -----------------------------------------------------------------------------
# This system MUST verify ALL .mdc files in .cursor/rules/ directory
# No operations can proceed without successful verification of ALL required files
