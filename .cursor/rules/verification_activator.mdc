# Verification System Activator
# ===========================
# IMPERATIVE - CRITICAL SYSTEM COMPONENT
# This file FORCES the verification system to be active and loaded FIRST
# DO NOT MODIFY WITHOUT EXPLICIT USER AUTHORIZATION

# Activation Protocol
# -----------------
activation_protocol:
  priority: "HIGHEST_POSSIBLE"
  execution_order: "FIRST"
  required_state:
    verification_active: true
    recovery_mode: false
    violation_count: 0

  forced_checks:
    before_any_action:
      - "Verify verification_system.mdc is loaded"
      - "Verify verification is active"
      - "Verify no active violations"
      - "Verify explicit user confirmation exists"
    failure_action:
      - "IMMEDIATELY STOP ALL OPERATIONS"
      - "Enter recovery mode"
      - "Notify user of system failure"
      - "Wait for explicit user instruction"

# Forced Verification Rules
# -----------------------
forced_rules:
  - "NO action can proceed without verification_system.mdc being active"
  - "NO action can proceed without explicit user confirmation"
  - "NO action can proceed if ANY MDC rule is violated"
  - "NO action can proceed if verification is not active"
  - "NO action can proceed if in recovery mode"
  - "NO action can proceed if violation_count > 0"

# Recovery Protocol
# ---------------
recovery_protocol:
  triggers:
    - "verification_system not loaded"
    - "verification not active"
    - "active violation detected"
    - "no explicit confirmation"
    - "MDC rule violation"
  actions:
    - "STOP ALL operations immediately"
    - "Enter recovery mode"
    - "Log violation with full context"
    - "Notify user of specific violation"
    - "Wait for explicit user instruction"
  exit_conditions:
    - "Explicit user instruction received"
    - "Verification system reactivated"
    - "All violations resolved"
    - "Full system state verified"

# Implementation Rules
# ------------------
implementation_rules:
  - "This activator MUST be loaded BEFORE any other system"
  - "This activator CANNOT be disabled"
  - "This activator MUST force verification on EVERY action"
  - "This activator MUST stop ALL operations if verification fails"
  - "This activator MUST maintain recovery mode until explicitly cleared"
  - "This activator MUST log ALL violations and recovery actions"

# Usage Rules
# ----------
usage_rules:
  - "Activator MUST be active in EVERY session"
  - "Activator MUST verify EVERY action"
  - "Activator MUST require explicit confirmation"
  - "Activator MUST stop on ANY violation"
  - "Activator MUST maintain recovery mode until cleared"
  - "Activator MUST log ALL violations"

# REMINDER: THIS ACTIVATOR IS IMPERATIVE AND CANNOT BE DISABLED
# -----------------------------------------------------------
# This activator FORCES the verification system to be active and prevents
# ANY action that would violate MDC rules. It cannot be disabled or overridden
# without explicit user authorization and system verification.
