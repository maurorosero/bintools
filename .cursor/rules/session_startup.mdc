# Session Startup Protocol Definition
# =================================
# IMPERATIVE - CRITICAL SYSTEM COMPONENT
# This file defines the protocol for starting and managing Cursor IDE sessions.
# DO NOT MODIFY WITHOUT EXPLICIT USER AUTHORIZATION.
# Session Startup Protocol
# ======================
# IMPERATIVE - MUST BE LOADED AT SESSION START
# This file defines the mandatory session initialization sequence

# Startup Sequence
# --------------
startup_sequence:
  priority: "HIGHEST"
  execution_order:
    1: "Load verification_activator.mdc"
    2: "Verify activator loaded successfully"
    3: "Activate verification system"
    4: "Verify verification system active"
    5: "Load remaining .mdc files"
    6: "Verify all files loaded"
    7: "Initialize session state"
    8: "Verify session state"

  required_state:
    verification_active: true
    activator_loaded: true
    all_mdc_loaded: true
    session_initialized: true

  validation_rules:
    - "verification_activator.mdc MUST be loaded FIRST"
    - "Verification system MUST be active"
    - "ALL .mdc files MUST be loaded"
    - "Session state MUST be valid"

  failure_action:
    - "STOP ALL OPERATIONS"
    - "Enter recovery mode"
    - "Notify user of startup failure"
    - "Wait for explicit user instruction"

# Initial Verification Definition
# ----------------------------
initial_verification:
  verification_system:
    priority: "HIGHEST"
    required_file: ".cursor/rules/verification_system.mdc"
    validation_rules:
      - "File MUST exist"
      - "File MUST be loadable"
      - "File MUST be valid .mdc format"
      - "File MUST NOT be empty"
      - "System MUST be activated"
    failure_action:
      - "STOP ALL OPERATIONS"
      - "Notify user of critical system failure"
      - "Wait for explicit user instruction"

  compliance_system:
    priority: "HIGHEST"
    required_file: ".cursor/rules/compliance_enforcement.mdc"
    validation_rules:
      - "File MUST exist"
      - "File MUST be loadable"
      - "File MUST be valid .mdc format"
      - "File MUST NOT be empty"
    failure_action:
      - "STOP ALL OPERATIONS"
      - "Notify user of critical system failure"
      - "Wait for explicit user instruction"

  rule_loading:
    priority: "HIGH"
    required_files:
      - ".cursor/rules/interaction_protocols.mdc"
      - ".cursor/rules/learned-memories.mdc"
      - ".cursor/rules/commit_standards.mdc"
      - ".cursor/rules/ci_cd_commit_policy.mdc"
      - ".cursor/rules/cli_banner_standard.mdc"
      - ".cursor/rules/create_rules.mdc"
      - ".cursor/rules/memory.mdc"
    validation_rules:
      - "ALL files MUST exist"
      - "ALL files MUST be loadable"
      - "ALL files MUST be valid .mdc format"
      - "NO file can be empty"
    failure_action:
      - "STOP ALL OPERATIONS"
      - "Notify user of missing/unloadable files"
      - "Provide exact list of missing files"
      - "Wait for user instruction"

# Session State Definition
# ----------------------
session_state:
  verification:
    check_points:
      - "session_start"
      - "verification_system_activation"
      - "rule_application"
      - "user_interaction"
      - "system_operation"
    validation_rules:
      - "Verification system MUST be active"
      - "Compliance system MUST be active"
      - "ALL rules MUST be loaded"
      - "System state MUST be valid"
    failure_action:
      - "STOP ALL OPERATIONS"
      - "Notify user"
      - "Wait for explicit user instruction"

# Error Handling Definition
# -----------------------
error_handling:
  verification_failure:
    priority: "HIGHEST"
    validation_rules:
      - "ANY verification failure MUST be detected"
      - "ALL failures MUST be logged"
      - "User MUST be notified"
    action_rules:
      - "IMMEDIATELY STOP ALL OPERATIONS"
      - "Log failure with full context"
      - "Notify user of specific failure"
      - "Wait for explicit user instruction"

  compliance_violation:
    priority: "HIGHEST"
    validation_rules:
      - "ANY violation MUST be detected"
      - "ALL violations MUST be logged"
      - "User MUST be notified"
    action_rules:
      - "IMMEDIATELY STOP ALL OPERATIONS"
      - "Log violation with full context"
      - "Notify user of specific violation"
      - "Wait for explicit user instruction"

# Rule Update Protocol Definition
# -----------------------------
rule_update:
  validation_rules:
    - "Changes MUST be logged"
    - "User MUST be notified"
    - "Changes MUST be reflected in learned-memories.mdc"
    - "Verification system MUST be updated"
  action_rules:
    - "Next session MUST load updated rules"
    - "Changes MUST be verified"
    - "User MUST confirm changes"
    - "Verification system MUST be reactivated"

# Implementation Rules
# ------------------
implementation_rules:
  - "This protocol MUST be executed at session start"
  - "verification_activator.mdc MUST be loaded FIRST"
  - "NO operations can proceed without verification active"
  - "Session MUST be in valid state before proceeding"
  - "ALL failures MUST trigger recovery mode"

# Usage Rules
# ----------
usage_rules:
  - "Protocol MUST be executed at session start"
  - "Protocol MUST load verification_activator.mdc FIRST"
  - "Protocol MUST verify ALL systems"
  - "Protocol MUST maintain session state"
  - "Protocol MUST stop on ANY failure"

# REMINDER: THIS PROTOCOL IS IMPERATIVE AND MUST BE EXECUTED AT SESSION START
# ------------------------------------------------------------------------
# This protocol ensures that the verification system is active and all
# required systems are properly initialized before any operations begin.
