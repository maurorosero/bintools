# rclone              # Sincronización de archivos con servicios cloud
# gvfs                # Sistema de archivos virtual para GNOME
# gvfs-smb            # Backends adicionales para GVFS (incluye SMB)
# gvfs-fuse           # Acceso FUSE a volúmenes virtuales GNOME

