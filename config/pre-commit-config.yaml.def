repos:
  - repo: local
    hooks:
      - id: manage-headers
        name: Manage File Headers
        entry: python ./header_manage.py
        language: python
        files: \.(py|ts|sh|js)$
        args: []
  - repo: local
    hooks:
      - id: commitlint
        name: Validate commit message format
        entry: ./commitlint-wrapper.sh
        language: script
        stages: [commit-msg] 