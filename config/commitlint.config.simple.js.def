const VERSION = "0.1.0"; // Version para el script de versionado
module.exports = {
  extends: ['@commitlint/config-simple'],
  rules: {
    'type-enum': [
      2,
      'always',
      [
        'IMPROVE',  // Mejoras generales
        'FIX',      // Correcciones
        'DOCS',     // Documentación
        'STYLE',    // Estilo de código
        'REFACTOR', // Refactorización
        'PERF',     // Rendimiento
        'TEST',     // Tests
        'BUILD',    // Build
        'CI',       // CI/CD
        'CHORE'     // Mantenimiento
      ]
    ],
    'type-case': [2, 'always', 'upper-case'],
    'type-empty': [2, 'never'],
    'scope-empty': [2, 'always'],
    'scope-case': [0],
    'subject-empty': [2, 'never'],
    'subject-case': [0],
    'header-max-length': [2, 'always', 100]
  }
}; 