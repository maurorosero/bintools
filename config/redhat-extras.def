# Archivo de paquetes extras para RHEL/CentOS
# Cada línea debe contener el nombre de un paquete para instalar
# Las líneas que comienzan con # son comentarios y serán ignoradas

# Herramientas de desarrollo
gcc               # Compilador GNU C
gcc-c++           # Compilador GNU C++
make              # Herramienta de construcción
cmake             # Sistema de construcción multiplataforma

# Utilidades del sistema
htop              # Monitor de procesos interactivo
epel-release      # Repositorio Extra Packages for Enterprise Linux
yum-utils         # Utilidades para YUM/DNF
ncdu              # Analizador de uso de disco
lsof              # Lista archivos abiertos

# Editores
vim-enhanced      # Editor de texto avanzado
nano              # Editor de texto simple

# Herramientas de red y seguridad
nmap              # Escáner de puertos
# fail2ban        # Protección contra ataques de fuerza bruta
# firewalld       # Firewall dinámico
# tcpdump         # Analizador de paquetes de red

# Otras utilidades
unzip             # Descompresor de archivos ZIP
tree              # Muestra directorios en forma de árbol
rsync             # Herramienta de sincronización remota
tmux              # Multiplexor de terminal 