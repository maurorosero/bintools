# Archivo de paquetes extras para openSUSE/SUSE Linux Enterprise
# Cada línea debe contener el nombre de un paquete para instalar
# Las líneas que comienzan con # son comentarios y serán ignoradas
# Nota: Los siguientes paquetes están en suse-base.pkg:
# - curl
# - git 
# - wget
# - python3
# - python3-pip
# - jq
# - gnupg2
# - dialog 

# Herramientas de desarrollo
# gcc                 # Compilador GNU C
# gcc-c++             # Compilador GNU C++
# make                # Herramienta de construcción
# cmake               # Sistema de construcción multiplataforma
# clang               # Compilador LLVM C/C++
# github-cli          # Github Manager CLI
# glab                # Gilab Manager CLI

# Utilidades del sistema
# htop                # Monitor de procesos interactivo
# neofetch            # Herramienta de información del sistema
# net-tools           # Herramientas de red básicas
# ncdu                # Analizador de uso de disco

# Editores
# vim                 # Editor de texto avanzado
# nano                # Editor de texto simple

# Herramientas de red y seguridad
# nmap                # Escáner de puertos
# fail2ban            # Protección contra ataques de fuerza bruta
# SuSEfirewall2       # Firewall dinámico para SUSE Linux

# Otras utilidades
# unzip               # Descompresor de archivos ZIP 
# tree                # Muestra directorios en forma de árbol
# tldr                # Páginas de ayuda simplificadas
# rsync               # Herramienta de sincronización remota
# tmux                # Multiplexor de terminal 

# Herramientas de mensajería
# python3-telethon    # Biblioteca Python para interactuar con la API de Telegram

# Herramientas para Markdown
# python3-Markdown    # Biblioteca Python para procesar Markdown
# python3-nbconvert   # Convierte Jupyter notebooks a otros formatos
# rubygem-kramdown    # Procesador de Markdown en Ruby con extensiones
# discount            # Implementación de Markdown en C

# Herramientas para desarrollo nodejs
# nodejs              # Plataforma JavaScript del lado del servidor
# npm                 # Gestor de paquetes de Node.js

# Herramientas ofimáticas
# libreoffice         # Suite ofimática completa
# hunspell-es         # Corrector ortográfico en español
# hunspell-en         # Corrector ortográfico en inglés
# pdfgrep             # Buscar texto en archivos PDF
# poppler-tools       # Utilidades para manipular PDF
# ghostscript         # Intérprete para PostScript y PDF
# pandoc              # Conversor universal de documentos
# texlive             # Sistema de composición de textos TeX/LaTeX
# cups                # Sistema de impresión
# scribus             # Publicación de escritorio profesional
# inkscape            # Editor de gráficos vectoriales
# gimp                # Editor de imágenes rasterizadas

# Herramientas para conexión remota y compartición de archivos
# filezilla           # Cliente FTP/SFTP con interfaz gráfica
# lftp                # Cliente FTP avanzado para línea de comandos
# ncftp               # Cliente FTP mejorado para línea de comandos
# ftp                 # Cliente FTP tradicional para línea de comandos
# samba               # Suite de herramientas SMB/CIFS para Linux
# samba-client        # Cliente para acceder a recursos SMB/CIFS
# cifs-utils          # Herramientas para montar shares SMB/CIFS
# fuse-sshfs          # Montar sistemas de archivos a través de SSH
# davfs2              # Montar sistemas de archivos WebDAV
# rclone              # Sincronización de archivos con servicios cloud

# Herramientas de visualización y exploración de datos/archivos
# visidata            # Herramienta TUI para explorar y analizar datos
# ranger              # Gestor de archivos en modo texto
# mc                  # Midnight Commander, gestor de archivos con interfaz de texto
# bat                 # Alternativa a cat con resaltado de sintaxis
# hexyl               # Visor de archivos hexadecimal moderno y colorido
# fzf                 # Buscador difuso en línea de comandos
# glow                # Renderizador de markdown en terminal
# fd                  # Alternativa moderna al comando find
# pv                  # Pipe Viewer - para monitorear progreso de datos en pipes
# multitail           # Visualizar múltiples archivos de log simultáneamente

# Desarrollo con Arduino
# arduino             # IDE y core de Arduino para desarrollo
# avrdude             # Software para programar microcontroladores Atmel AVR
# cross-avr-gcc       # Compilador GCC para microcontroladores AVR
# cross-avr-libc      # Biblioteca C estándar para AVR
# picocom             # Monitor serial minimalista para comunicación
# screen              # Multiplexor de terminal (útil para monitoreo serial)
# python3-pyserial    # Módulo Python para comunicación serial
# stm32flash          # Herramienta para flashear MCUs STM32
# esptool             # Herramienta para programar chips ESP8266/ESP32
# openocd             # Depurador on-chip para programación y depuración
# fritzing            # Diseño de circuitos y PCB para prototipado

# Python y entorno de desarrollo
# Nota: python3 y python3-pip ya están en paquetes base
# python3-virtualenv  # Soporte para entornos virtuales en Python3
# python3-setuptools  # Herramientas para instalación de paquetes Python
# python3-wheel       # Sistema de empaquetado y distribución para Python
# python3-mypy        # Verificador de tipos estáticos para Python
# python3-black       # Formateador de código para Python
# python3-flake8      # Linter para código Python
# python3-ipython     # Shell interactiva mejorada para Python

# Herramientas para compilación de Python a ejecutables
# python3-Cython      # Compilador que convierte Python a C
# gcc                 # Compilador de C (necesario para compilar extensiones)
# patchelf            # Herramienta para modificar binarios ELF
# upx                 # Compresor de ejecutables

# Herramientas SSH
# openssh             # Cliente SSH básico
# openssh-server      # Servidor SSH
# sshpass             # Automatización de contraseñas SSH (usar con precaución)
# keychain            # Gestor de llaves SSH basado en ssh-agent
# openssh-askpass     # Herramienta gráfica para solicitar contraseñas SSH
# autossh             # Mantiene y restaura automáticamente conexiones SSH
# mosh                # Alternativa a SSH resiliente a conexiones intermitentes
# pssh                # Ejecución en paralelo de SSH para múltiples servidores
# sshuttle            # VPN transparente sobre SSH
# asciinema           # Graba y comparte sesiones de terminal
# ttyd                # Comparte terminal vía navegador web

# Herramientas para DevOps
# ansible             # Plataforma de automatización IT
# python3-yq          # Procesador de YAML en línea de comandos
# git-lfs             # Extensión de Git para archivos grandes
# httpie              # Cliente HTTP amigable para CLI
# bind-utils          # Herramientas para diagnóstico DNS
# tcpdump             # Analizador de paquetes de red
# mtr                 # Combinación de traceroute y ping
# iotop               # Monitor de uso de I/O por procesos
# sysstat             # Utilidades para monitoreo de rendimiento
# netcat-openbsd      # Utilidad de red versátil 