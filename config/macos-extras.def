# Archivo de paquetes extras para macOS (via Homebrew)
# Cada línea debe contener el nombre de un paquete para instalar
# Las líneas que comienzan con # son comentarios y serán ignoradas
# Nota: Los siguientes paquetes están en macos-base.pkg:
# - curl
# - git
# - wget
# - python3
# - pip3
# - jq
# - gnupg
# - dialog

# Herramientas de desarrollo
# gcc                 # Compilador GNU C
# g++                 # Compilador GNU C++
# make                # Herramienta de construcción GNU Make
# cmake               # Sistema de construcción multiplataforma
# clang               # Compilador LLVM C/C++
# llvm                # Herramientas y librerías Low Level Virtual Machine
# autoconf            # Herramienta para generar scripts de configuración
# automake            # Herramienta para generar Makefiles
# pkg-config          # Gestor de configuración para compilación
# gh                  # GitHub CLI
# glab                # GitLab CLI

# Utilidades del sistema
# htop                # Monitor de procesos interactivo
# neofetch            # Herramienta de información del sistema
# lsof                # Lista archivos abiertos
# ncdu                # Analizador de uso de disco
# duti                # Herramienta para gestionar asociaciones de archivos
# dockutil            # Gestión del Dock desde línea de comandos
# mas                 # Gestor de aplicaciones de Mac App Store en CLI
# trash               # Mover archivos a la papelera en lugar de borrarlos
# watch               # Ejecuta comandos periódicamente y muestra su salida
# coreutils           # Implementaciones GNU de herramientas básicas de Unix

# Editores
# vim                 # Editor de texto avanzado
# nano                # Editor de texto simple
# neovim              # Versión moderna de vim
# emacs               # Editor de texto extensible
# visual-studio-code  # Visual Studio Code

# Herramientas de red y seguridad
# nmap                # Escáner de puertos
# tcpdump             # Analizador de paquetes de red
# wireshark           # Analizador de protocolos de red
# mtr                 # Combinación de traceroute y ping
# netcat              # Utilidad de red versátil
# openssl             # Implementación de SSL y TLS
# ssh-copy-id         # Utilidad para copiar claves SSH
# sshuttle            # VPN transparente sobre SSH

# Otras utilidades
# unzip               # Descompresor de archivos ZIP
# p7zip               # Implementación del compresor 7z
# tree                # Muestra directorios en forma de árbol
# tldr                # Páginas de ayuda simplificadas
# rsync               # Herramienta de sincronización remota
# tmux                # Multiplexor de terminal
# zsh                 # Shell alternativa
# colordiff           # Versión de diff con salida en color
# bat                 # Alternativa a cat con resaltado de sintaxis
# fd                  # Alternativa simple y rápida a find
# fzf                 # Buscador difuso en línea de comandos
# ripgrep             # Alternativa rápida a grep
# the_silver_searcher # Herramienta de búsqueda de código muy rápida
# jq                  # Procesador de JSON en línea de comandos
# yq                  # Procesador de YAML en línea de comandos

# Herramientas para Markdown
# grip                # Renderizador de Markdown con estilo GitHub
# mdbook              # Crea libros con Markdown (similar a GitBook)
# pandoc              # Conversor universal de documentos
# markdown            # Implementación original de Markdown
# discount            # Implementación de Markdown en C
# multimarkdown       # Markdown con extensiones

# Herramientas para desarrollo nodejs
# node                # Plataforma JavaScript del lado del servidor
# npm                 # Gestor de paquetes de Node.js
# yarn                # Gestor de paquetes alternativo para Node.js

# Herramientas ofimáticas
# libreoffice         # Suite ofimática completa
# hunspell            # Corrector ortográfico
# pdfgrep             # Buscar texto en archivos PDF
# poppler             # Utilidades para manipular PDF
# ghostscript         # Intérprete para PostScript y PDF
# pandoc              # Conversor universal de documentos
# texlive             # Distribución de TeX/LaTeX
# mactex              # Distribución de TeX/LaTeX para macOS
# calibre             # Gestor de libros electrónicos

# Herramientas para conexión remota y compartición de archivos
# filezilla           # Cliente FTP/SFTP con interfaz gráfica
# lftp                # Cliente FTP avanzado para línea de comandos
# ncftp               # Cliente FTP mejorado para línea de comandos
# osxfuse             # Sistema de archivos en espacio de usuario
# sshfs               # Montar sistemas de archivos a través de SSH
# rclone              # Sincronización de archivos con servicios cloud

# Herramientas de visualización y exploración de datos/archivos
# visidata            # Herramienta TUI para explorar y analizar datos
# ranger              # Gestor de archivos en modo texto
# mc                  # Midnight Commander, gestor de archivos con interfaz de texto
# hexyl               # Visor de archivos hexadecimal moderno y colorido
# jless               # Paginador para JSON
# miller              # Procesador de datos tipo CSV/TSV/JSON
# pv                  # Pipe Viewer - para monitorear progreso de datos en pipes
# glow                # Renderizador de markdown en terminal

# Desarrollo con Arduino
# arduino-cli         # Arduino CLI para desarrollo
# avrdude             # Software para programar microcontroladores Atmel AVR
# avr-gcc             # Compilador GCC para microcontroladores AVR
# avr-libc            # Biblioteca C estándar para AVR
# picocom             # Monitor serial minimalista para comunicación
# screen              # Multiplexor de terminal (útil para monitoreo serial)
# pyserial            # Módulo Python para comunicación serial
# platformio          # Framework de desarrollo para IoT
# stm32flash          # Herramienta para flashear MCUs STM32
# esptool             # Herramienta para programar chips ESP8266/ESP32
# openocd             # Depurador on-chip para programación y depuración

# Python y entorno de desarrollo
# Nota: python3 y pip3 ya están en paquetes base
# python-tk           # Soporte de Tkinter para Python (GUI)
# virtualenv          # Soporte para entornos virtuales en Python
# pyenv               # Gestor de versiones de Python
# pipx                # Ejecutar aplicaciones Python en entornos aislados
# mypy                # Verificador de tipos estáticos para Python
# black               # Formateador de código para Python
# flake8              # Linter para código Python
# ipython             # Shell interactiva mejorada para Python
# jupyter             # Cuadernos interactivos para Python
# cython              # Compilador que convierte Python a C

# Herramientas para compilación de Python a ejecutables
# py2app               # Herramienta para empaquetar Python en app macOS
# pillow               # Biblioteca para procesamiento de imágenes
# pyinstaller          # Empaqueta Python en ejecutable

# Herramientas SSH
# openssh             # Cliente SSH básico (ya incluido en macOS)
# sshpass             # Automatización de contraseñas SSH (usar con precaución)
# keychain            # Gestor de llaves SSH basado en ssh-agent
# autossh             # Mantiene y restaura automáticamente conexiones SSH
# mosh                # Alternativa a SSH resiliente a conexiones intermitentes
# asciinema           # Graba y comparte sesiones de terminal
# ttyd                # Comparte terminal vía navegador web

# Herramientas para DevOps
# terraform           # Herramienta de infraestructura como código
# ansible             # Plataforma de automatización IT
# awscli              # CLI para Amazon Web Services
# azure-cli           # CLI para Microsoft Azure
# google-cloud-sdk    # SDK para Google Cloud Platform
# httpie              # Cliente HTTP amigable para CLI
# bind                # Herramientas para diagnóstico DNS
# tcpdump             # Analizador de paquetes de red
# mtr                 # Combinación de traceroute y ping
# netcat              # Utilidad de red versátil
# git-lfs             # Extensión de Git para archivos grandes

# Herramientas para contenedores
# docker              # Plataforma de contenedores Docker
# docker-compose      # Herramienta para definir aplicaciones multi-contenedor
# docker-machine      # Herramienta para crear hosts Docker
# kubectl             # Cliente para Kubernetes
# minikube            # Ejecuta Kubernetes localmente
# helm                # Gestor de paquetes para Kubernetes
