# Archivo de paquetes Snap para instalar
# Cada línea debe contener el nombre de un paquete snap
# Las líneas que comienzan con # son comentarios y serán ignoradas

# Herramientas de desarrollo
# code            # Visual Studio Code
# postman         # Cliente API
# insomnia        # Cliente API alternativo
# android-studio  # IDE para desarrollo Android

# Comunicación
# slack           # Chat de trabajo
# discord         # Chat de comunidades
telegram-desktop  # Mensajería

# Multimedia
spotify           # Reproductor de música
# vlc             # Reproductor multimedia
# obs-studio      # Software para streaming y grabación

# Productividad
# notion-snap     # Gestor de notas
# bitwarden       # Gestor de contraseñas
# libreoffice     # Suite ofimática

# Herramientas del sistema
# btop            # Administrador de procesos
# docker          # Contenedores
# multipass       # Máquinas virtuales de Ubuntu

# Navegadores
chromium          # Navegador Chromium
# brave           # Navegador Seguro basado en Chromium
# firefox         # Navegador Firefox

# Utilidades
# hugo            # Generador de sitios estáticos
# gimp            # Editor de imágenes
# inkscape        # Editor vectorial
# blender         # Software de modelado y animación 3D 