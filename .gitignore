# Gitignore para scripts en ~/bin
# Creado el 24 de abril de 2025

### Bash ###
# Temporales y backups
*.swp
*.bak
*~

# Logs y archivos de sesión
*.log
nohup.out

# Archivos de configuración local
.env
.env.local
.env.*.local
config.local.sh
config/snap.pkg
config/*-extras.pkg

### Python ###
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribución / empaquetado
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Entornos virtuales - modificado para mantener la carpeta pero ignorar su contenido
# venv/  <- comentado para no ignorar la carpeta
venv/*  # Ignora todo el contenido de venv/
!venv/.gitkeep  # Pero no ignores el archivo .gitkeep

ENV/
env/
.venv/
.env/
.virtualenv/

# Jupyter Notebook
.ipynb_checkpoints

### Node.js y npm ###
# Directorio de dependencias
node_modules/

# Logs
logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Archivos de bloqueo de versiones
package-lock.json
yarn.lock

# Archivos de entorno específicos de Node.js
.env.development.local
.env.test.local
.env.production.local

# Directorio de configuración de npm
.npm/

# Historiales y caché
.node_repl_history
.eslintcache
.yarn-integrity

# Archivos de distribución
.next/
.cache/
.nuxt/
dist/

# Archivos de paquetes
*.tgz

# Archivos de datos y salidas
*.csv
*.json
*.xlsx
*.db
*.sqlite
output/

# Asegurar seguimiento de archivos específicos
!config/mcp_servers.yaml
!package.json
# Asegurar que se realiza seguimiento de archivos requirements.txt en raíz
!requirements.txt
!*_requirements.txt